# OPL for Cancer — environment template.
# Copy to .env and fill in. None are committed; .env is in .gitignore.

# ── LLM providers ─────────────────────────────────────────────────────────
# At least one is required. Both is ideal (cross-model reviewer diversity
# enforced by G13 mechanical gate per models.yaml).
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
# Optional tertiary reviewer for second-opinion when MiniMax + Claude disagree.
OPENAI_API_KEY=

# ── Patient data root ─────────────────────────────────────────────────────
# Where patient records, run artefacts, and Project Memory live. Defaults to
# ~/CancerDAO/patients/ . The skill never touches anything outside this root.
OPL_PATIENT_DATA_ROOT=

# ── Integrators (most public APIs need only a contact email) ──────────────
# PubMed / NCBI E-utilities — public; provide email for higher rate limit.
NCBI_EMAIL=
NCBI_API_KEY=

# OncoKB requires a registered API token. Public read access is rate-limited
# without one.
ONCOKB_API_KEY=

# CIViC and Open Targets are public; no key required.
# ClinVar / gnomAD / RetractionDB are public; no key required.
# ClinicalTrials.gov is public; no key required.
# ChiCTR is public; the integrator uses HTML scraping with caching.
# cBioPortal / GDC are public; no key required.
# GEO / ArrayExpress / SRA are public; for large downloads, set:
SRA_TOOLKIT_PATH=
# DepMap / CCLE are public via depmap.org figshare.
# NMPA-EAP / FDA-EAP — public web sources; integrator caches HTML.
# Unpaywall requires a contact email (UNPAYWALL_EMAIL) per their TOS:
UNPAYWALL_EMAIL=

# PaperQA2 (local RAG index) — path to the .pqa folder. Will be created on
# first build.
PAPERQA_INDEX_PATH=

# Lexicomp is license-restricted. Default integrator falls back to RxNorm +
# DrugBank (open). If you have institutional Lexicomp access, set:
LEXICOMP_API_KEY=

# ── Compute runtime (Wave 3 only) ─────────────────────────────────────────
# Docker for Finch / bixbench reanalysis container. Wave 1/2/4/5 do not need it.
OPL_BIXBENCH_IMAGE=opl-cancer/bixbench:latest

# ── Observability / debug ────────────────────────────────────────────────
OPL_LOG_LEVEL=INFO
OPL_TELEMETRY_ENABLED=false   # set to true to emit metrics to tools/observe.py

# ── Founder-mode discipline knobs (do not change without reading docs) ────
# 0 disables — but doing so violates the founder-mode philosophy.
OPL_REQUIRE_PMID_ANCHOR=1            # G2 mechanical gate
OPL_REQUIRE_LEVEL34_RISK_CARD=1      # G8 mechanical gate
OPL_REQUIRE_DIFFERENT_REVIEWER_MODEL=1  # G13 mechanical gate
