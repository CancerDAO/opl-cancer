<!doctype html>
<html lang="{{ language }}">
<head>
<meta charset="utf-8">
<title>Patient Brief — {{ patient_code }} — {{ run_id }}</title>
<style>
  body { font-family: -apple-system, "Segoe UI", sans-serif; max-width: 880px; margin: 2em auto; padding: 0 1em; line-height: 1.5; }
  .tier { padding: 0.2em 0.6em; border-radius: 4px; font-size: 0.8em; }
  .established { background: #c8e6c9; color: #1b5e20; }
  .exploratory { background: #fff3b0; color: #7a5e00; }
  .speculative { background: #ffccbc; color: #bf360c; }
  .risk-card { border: 2px solid #d32f2f; padding: 1em; background: #ffebee; margin: 1em 0; }
  details { margin-top: 0.5em; }
  .pmid { font-family: monospace; font-size: 0.9em; color: #1565c0; }
  .disagreement { background: #f3e5f5; padding: 0.5em; border-left: 4px solid #6a1b9a; }
  .world-unknown { border: 2px dashed #b85c00; padding: 1.2em; margin: 2em 0; background: #fff8f0; }
  .world-unknown h2 { color: #b85c00; margin-top: 0; }
  .world-unknown .disclaimer-strong {
    border: 2px solid #d32f2f;
    background: #ffebee;
    color: #b71c1c;
    padding: 0.8em 1em;
    margin: 0.5em 0 1.2em 0;
    font-weight: 700;
    font-size: 1em;
    border-radius: 4px;
  }
  .world-unknown .framing { font-size: 0.95em; color: #444; margin-bottom: 1em; }
  .world-unknown li { margin-bottom: 1.2em; padding: 0.6em; background: #ffffff; border-left: 4px solid #b85c00; }
  .world-unknown .candidate-notice {
    display: inline-block;
    background: #fff3cd;
    color: #856404;
    padding: 2px 8px;
    border-radius: 3px;
    font-size: 0.8em;
    margin-left: 6px;
    font-weight: 600;
  }
  .world-unknown .candidate-banner {
    color: #b71c1c;
    font-weight: 700;
    font-size: 0.85em;
    margin-bottom: 0.4em;
  }
  .actionable-paths { border: 2px solid #2e7d32; padding: 1.2em; margin: 2em 0; background: #f1f8f2; border-radius: 6px; }
  .actionable-paths h2 { color: #2e7d32; margin-top: 0; }
  .actionable-paths .framing { font-size: 0.95em; color: #444; margin-bottom: 1em; }
  .actionable-paths li { margin-bottom: 1em; padding: 0.6em; background: #ffffff; border-left: 4px solid #2e7d32; }
  .actionable-paths .this-week {
    display: inline-block; background: #c8e6c9; color: #1b5e20;
    padding: 2px 8px; border-radius: 3px; font-size: 0.8em; font-weight: 700; margin-right: 6px;
  }
</style>
</head>
<body>
<h1>Patient Brief — {{ patient_code }}</h1>
<p><em>Run {{ run_id }} · {{ created_at }}</em></p>

{% if delivery_blocked_notice is defined and delivery_blocked_notice %}
<div style="border: 3px solid #b71c1c; background: #fdecea; padding: 1em; margin: 1em 0; color: #7f0000; font-weight: 700;">
<strong>🚫 交付已阻断 / DELIVERY BLOCKED:</strong> {{ delivery_blocked_notice }}
</div>
{% endif %}

{% if run_incomplete_notice is defined and run_incomplete_notice %}
<div style="border: 3px solid #d32f2f; background: #ffebee; padding: 1em; margin: 1em 0; color: #b71c1c;">
<strong>⚠️ 本次 RUN 不完整 / INCOMPLETE RUN:</strong> {{ run_incomplete_notice }}
</div>
{% endif %}

{% for card in risk_cards %}
<div class="risk-card">
  <strong>Risk Disclosure (Level {{ card.level }}):</strong> {{ card.message }}
  {% if card.requires_ack %}<p><strong>Acknowledgment required before acting.</strong></p>{% endif %}
</div>
{% endfor %}

<h2>Summary</h2>
<p>{{ sid_summary }}</p>

<h2>Findings by Expert</h2>
{% for ex in experts %}
<h3>{{ ex.name | capitalize }} — {{ ex.role }}</h3>
{% for claim in ex.claims %}
<p><span class="tier {{ claim.layer }}">{{ claim.layer }}</span> {{ claim.text }}</p>
<ul>
  {% for ev in claim.evidence %}
  <li>
    {% if ev.type == "pmid" %}<a class="pmid" href="https://pubmed.ncbi.nlm.nih.gov/{{ ev.id }}/">PMID:{{ ev.id }}</a>
    {% else %}{{ ev.type }}: {{ ev.id }}{% endif %}
    — &ldquo;{{ ev.quote }}&rdquo;
  </li>
  {% endfor %}
</ul>
{% if claim.reviewer_challenges %}
<div class="disagreement"><strong>Reviewer challenges:</strong>
<ul>{% for ch in claim.reviewer_challenges %}<li>{{ ch }}</li>{% endfor %}</ul>
</div>
{% endif %}
<p><small>provenance: <code>{{ claim.provenance_hash }}</code></small></p>
{% endfor %}
{% endfor %}

{% if has_actionable_paths is defined and has_actionable_paths %}
<section class="actionable-paths">
<h2>🧭 可以走的路 / Paths you could take</h2>
<p class="framing">
下面是团队在公开数据库里<strong>找到的真实、可执行</strong>的选择 — 临床试验、下一线方案、扩展准入 / 同情用药通道。<strong>这不是治疗建议</strong>，是给您和主治医生讨论用的真实选项清单。决策权始终在您（与您的医生）手里。
</p>
{% if matches and matches|length > 0 %}
<h3>🔬 临床试验匹配 / Clinical trial matches</h3>
<ul>
{% for m in matches %}
<li>
  <span class="this-week">✅ 本周内可了解 / Actionable this week</span>
  <strong>{{ m.get('title') or m.get('nct_id') or m.get('id') or m.get('trial_id') }}</strong>{% if m.get('nct_id') %} <code>{{ m.get('nct_id') }}</code>{% endif %}
  {% if m.get('phase') %}<br><small>期别 / Phase: {{ m.get('phase') }}</small>{% endif %}
  {% if m.get('status') %}<br><small>状态 / Status: {{ m.get('status') }}</small>{% endif %}
  {% if m.get('eligibility_summary') or m.get('summary') %}<br>{{ m.get('eligibility_summary') or m.get('summary') }}{% endif %}
  {% if m.get('locations') %}<br><small>地点 / Sites: {{ m.get('locations') if m.get('locations') is string else m.get('locations')|join(', ') }}</small>{% endif %}
</li>
{% endfor %}
</ul>
{% endif %}
{% if studies and studies|length > 0 %}
<h3>📈 下一线方案研究 / Next-line studies</h3>
<ul>
{% for s in studies %}
<li>
  <span class="this-week">✅ 本周内可了解 / Actionable this week</span>
  {{ s.get('summary') or s.get('title') or s.get('text') or s.get('id') }}
  {% if s.get('evidence') %}<ul>{% for ev in s.get('evidence') or [] %}<li>{% if ev.get('type') == "pmid" %}<a class="pmid" href="https://pubmed.ncbi.nlm.nih.gov/{{ ev.get('id') }}/">PMID:{{ ev.get('id') }}</a>{% else %}{{ ev.get('type') }}: {{ ev.get('id') }}{% endif %}{% if ev.get('quote') %} — &ldquo;{{ ev.get('quote') }}&rdquo;{% endif %}</li>{% endfor %}</ul>{% endif %}
</li>
{% endfor %}
</ul>
{% endif %}
{% if expanded_access_routes and expanded_access_routes|length > 0 %}
<h3>🛂 扩展准入 / 同情用药 · Expanded access / compassionate use</h3>
<ul>
{% for r in expanded_access_routes %}
<li>
  <span class="this-week">✅ 本周内可了解 / Actionable this week</span>
  <strong>{{ r.get('program') or r.get('title') or r.get('summary') or r.get('text') or r.get('id') }}</strong>{% if r.get('jurisdiction') %} ({{ r.get('jurisdiction') }}){% endif %}
  {% if r.get('drug') or r.get('drug_class') %}<br><small>药物 / Drug: {{ r.get('drug') or r.get('drug_class') }}</small>{% endif %}
  {% if r.get('contact') or r.get('how_to_apply') %}<br><small>申请途径 / How to apply: {{ r.get('contact') or r.get('how_to_apply') }}</small>{% endif %}
</li>
{% endfor %}
</ul>
{% endif %}
</section>
{% endif %}

{% if world_unknown_candidates is defined and world_unknown_candidates and world_unknown_candidates|length > 0 %}
<section class="world-unknown">
<h2>⚡ World-Unknown / Speculative Candidates — Research Directions (研究方向)</h2>
<div class="disclaimer-strong">
⚠️ 这不是治疗建议 / THIS IS NOT A TREATMENT RECOMMENDATION<br>
本节列出的是<strong>未发表 / 未验证</strong>的研究方向候选。仅供患者与团队作为下一步研究讨论的起点。<strong>任何治疗决策必须由主治医生在完整临床证据基础上做出</strong>。
</div>
<p class="framing">
本节列出本次 run 中由 Maya（KG-synergy）/ Julius（in-silico drug design）/ Aviv（data-driven hypogenesis）产生的世界未知候选。本节是 OPL 与 MTB 的核心差异点——明确标注未发表的候选并附可测路径，决策权由患者保留。
</p>
<ul>
{% for cand in world_unknown_candidates %}
<li>
  <div class="candidate-banner">⚠️ 研究方向 — 不是治疗建议 · NOT a recommendation</div>
  {% if cand.actionability_label_zh is defined %}
  <div style="font-weight: 600; color: #555; margin-bottom: 0.4em;">优先级 / Actionability: {{ cand.actionability_label_zh }}</div>
  {% endif %}
  <strong>{{ cand.text }}</strong>
  <span class="candidate-notice">[S] speculative</span>
  <br><small style="color: #666;">Strategy: <code>{{ cand.generation_strategy }}</code>{% if cand.elo_rating is defined and cand.elo_rating %} · Elo: {{ cand.elo_rating }}{% endif %}</small>
  {% if cand.testability_path %}
  <br><strong>下一步测试路径 / Testability path:</strong> {{ cand.testability_path }}
  {% endif %}
  {% if cand.evidence_refs %}
  <br><strong>Anchors (⚠️ 未独立校验 / NOT independently verified):</strong>
    {% for ref in cand.evidence_refs %}<code>{{ ref.type }}:{{ ref.id }}</code>{% if not loop.last %}, {% endif %}{% endfor %}
  {% endif %}
  {% if cand.redacted_drug_names is defined and cand.redacted_drug_names and cand.redacted_drug_names|length > 0 %}
  <br><small style="color: #888;">（具体药名已隐去 / specific drug names redacted to target class; 共 {{ cand.redacted_drug_names|length }} 项）</small>
  {% endif %}
</li>
{% endfor %}
</ul>
</section>
{% endif %}

<hr>
<p><small>Generated by OPL for Cancer (Apache-2.0). PI=Sid, Auditor=Henry.</small></p>
</body>
</html>
